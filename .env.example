# ============================================
# Digital Self 环境变量配置
# 复制为 .env 后按需修改
# ============================================

# LLM 提供商（选择其中一个配置即可）
# 可选值: mimo / deepseek / openai / custom
ACTIVE_PROVIDER=mimo

# MiMo API 配置
MIMO_API_KEY=your-mimo-api-key
MIMO_API_BASE=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# DeepSeek API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API 配置
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 自定义 Provider（兼容 OpenAI 格式的任意 API）
CUSTOM_API_BASE=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# 数据库（本地用 SQLite，Docker 部署时切换 PostgreSQL）
DATABASE_URL=sqlite:///./digital_self.db

# 检索模式
# lite  = TF-IDF 文本检索（默认，无需额外依赖）
# full  = Ollama + bge-m3 向量检索（需安装 Ollama）
EMBEDDING_MODE=lite
EMBEDDING_DIMENSION=1024

# Ollama 配置（Full 模式使用）
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant 向量库（Full 模式启用）
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_ENABLED=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LightRAG 知识图谱
LIGHTRAG_ENABLED=true
LIGHTRAG_WORKING_DIR=../data/lightrag
LIGHTRAG_QUERY_MODE=hybrid

# 应用配置
APP_NAME=Digital Self
DEBUG=true
SHORT_TERM_MEMORY_LIMIT=20
MEMORY_IMPORTANCE_THRESHOLD=5
DISTILL_SCHEDULE=weekly
